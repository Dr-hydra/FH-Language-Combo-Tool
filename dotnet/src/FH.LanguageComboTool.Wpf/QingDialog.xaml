<Window x:Class="FH.LanguageComboTool.Wpf.QingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:qing="clr-namespace:QING.UIKIT;assembly=QING.UIKIT"
        Style="{StaticResource MyWindow}"
        Width="470"
        MinHeight="210"
        MaxHeight="620"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Background="{x:Null}"
        KeyDown="Dialog_KeyDown">
    <Border Margin="12"
            CornerRadius="6"
            Background="{DynamicResource ColorBrushGray8}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.24" Color="#343d4a" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar"
                  Background="{DynamicResource ColorBrush4}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="TitleText"
                           Margin="16,0,48,0"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="15"
                           FontWeight="SemiBold" />
                <qing:MyIconButton HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Width="28"
                                   Height="28"
                                   Margin="0,0,10,0"
                                   Theme="White"
                                   LogoScale="0.65"
                                   Logo="F1 M2,0 L0,2 8,10 0,18 2,20 10,12 18,20 20,18 12,10 20,2 18,0 10,8 2,0Z"
                                   Click="Close_Click" />
            </Grid>

            <ScrollViewer Grid.Row="1"
                          MaxHeight="430"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="MessageText"
                           Margin="22,22,22,18"
                           FontSize="13"
                           LineHeight="22"
                           TextWrapping="Wrap" />
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="22,0,22,22">
                <qing:MyButton x:Name="SecondaryButton"
                               Text="否"
                               Padding="20,8"
                               Margin="0,0,10,0"
                               Visibility="Collapsed"
                               Click="Secondary_Click" />
                <qing:MyButton x:Name="PrimaryButton"
                               Text="确定"
                               Padding="20,8"
                               ColorType="Highlight"
                               Click="Primary_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
